.page {
  min-height: 100vh;
  background: var(--bg);
}

.topbar {
  box-sizing: border-box;
  min-height: 178rpx;
  padding: 48rpx 30rpx 24rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  background: var(--brand-deep);
  color: #ffffff;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: rgba(255, 255, 255, 0.78);
}

.status-dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  margin-right: 8rpx;
  border-radius: 50%;
  background: #ff9d8a;
}

.status-dot.online {
  background: #7cf0c0;
}

.sample-count {
  flex-shrink: 0;
  font-size: 23rpx;
  color: rgba(255, 255, 255, 0.8);
}

.content {
  height: calc(100vh - 178rpx);
  padding-bottom: 36rpx;
}

.metric-scroll {
  width: 100%;
  margin-top: 22rpx;
  white-space: nowrap;
}

.metric-tabs {
  display: inline-flex;
  padding: 0 24rpx;
  gap: 12rpx;
}

.metric-tab {
  min-width: 116rpx;
  height: 64rpx;
  padding: 0 18rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 25rpx;
  color: var(--ink-2);
  border: 1rpx solid var(--line);
  border-radius: var(--radius-sm);
  background: #ffffff;
}

.metric-tab.active {
  color: #ffffff;
  border-color: var(--brand);
  background: var(--brand);
  font-weight: 700;
}

.summary-grid {
  margin: 20rpx 24rpx 0;
  display: grid;
  grid-template-columns: 1.35fr 1fr 1fr 1fr;
  border: 1rpx solid var(--line);
  border-radius: var(--radius);
  overflow: hidden;
  background: #ffffff;
}

.summary-item {
  min-width: 0;
  padding: 22rpx 10rpx;
  border-left: 1rpx solid var(--line);
}

.summary-item:first-child {
  border-left: 0;
}

.summary-item.primary {
  background: var(--ok-soft);
}

.summary-label {
  font-size: 21rpx;
  color: var(--ink-3);
}

.summary-value {
  margin-top: 7rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ink);
  word-break: break-all;
}

.summary-value.compact {
  font-size: 23rpx;
}

.chart-section,
.alarm-section {
  margin: 20rpx 24rpx 0;
  padding: 24rpx;
  border: 1rpx solid var(--line);
  border-radius: var(--radius);
  background: #ffffff;
}

.range-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.range-options {
  display: flex;
  padding: 5rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  background: var(--muted-soft);
}

.range-option {
  min-width: 82rpx;
  height: 52rpx;
  padding: 0 10rpx;
  line-height: 52rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--ink-2);
  border-radius: 9rpx;
}

.range-option.active {
  color: var(--brand);
  background: #ffffff;
  font-weight: 700;
  box-shadow: var(--shadow-sm);
}

.rule {
  min-width: 0;
  text-align: right;
  font-size: 21rpx;
  color: var(--ink-3);
}

.trend-canvas {
  display: block;
  width: 100%;
  height: 430rpx;
  margin-top: 18rpx;
}

.chart-legend {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 21rpx;
  color: var(--ink-3);
}

.chart-legend .legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.threshold-line {
  width: 34rpx;
  border-top: 2rpx dashed var(--danger);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 29rpx;
  font-weight: 700;
  color: var(--ink);
}

.alarm-count {
  min-width: 44rpx;
  height: 44rpx;
  padding: 0 10rpx;
  box-sizing: border-box;
  line-height: 44rpx;
  text-align: center;
  font-size: 23rpx;
  border-radius: 22rpx;
  color: var(--ink-2);
  background: var(--muted-soft);
}

.alarm-count.has-alarm {
  color: #a83420;
  background: var(--danger-soft);
}

.normal-state {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx;
  background: var(--ok-soft);
  border-radius: var(--radius-sm);
}

.normal-icon {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  color: #ffffff;
  border-radius: 50%;
  background: var(--ok);
}

.normal-title,
.alarm-title {
  font-size: 25rpx;
  font-weight: 700;
  color: var(--ink);
}

.normal-copy,
.alarm-message {
  margin-top: 5rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--ink-2);
}

.alarm-list {
  margin-top: 18rpx;
}

.alarm-item {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
  padding: 18rpx;
  border-radius: var(--radius-sm);
  background: var(--warn-soft);
}

.alarm-item:first-child {
  margin-top: 0;
}

.alarm-item.alarm-danger {
  background: var(--danger-soft);
}

.alarm-marker {
  flex-shrink: 0;
  width: 10rpx;
  height: 58rpx;
  border-radius: 5rpx;
  background: var(--warn);
}

.alarm-danger .alarm-marker {
  background: var(--danger);
}
