.page {
  min-height: 100vh;
  background: #f3f6f4;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 28rpx 22rpx;
  background: #1f4f46;
  color: #ffffff;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
}

.status {
  min-width: 92rpx;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 6rpx;
  text-align: center;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.15);
}

.status.online {
  background: #d7f4e4;
  color: #12653f;
}

.status.offline {
  background: #f7dfdf;
  color: #963232;
}

.content {
  height: calc(100vh - 104rpx);
}

.connection-panel,
.section {
  margin: 20rpx 24rpx;
  padding: 22rpx;
  background: #ffffff;
  border: 1rpx solid #dfe7e3;
  border-radius: 8rpx;
}

.mode-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.mode-badge {
  width: 74rpx;
  height: 40rpx;
  line-height: 40rpx;
  border-radius: 6rpx;
  text-align: center;
  color: #ffffff;
  background: #1f7a62;
  font-size: 23rpx;
}

.mode-text {
  color: #63766f;
  font-size: 24rpx;
}

.input-row {
  display: flex;
  gap: 14rpx;
}

.text-input,
.token-input {
  height: 64rpx;
  padding: 0 18rpx;
  border: 1rpx solid #cfd9d4;
  border-radius: 6rpx;
  color: #17332d;
  font-size: 24rpx;
  background: #fbfcfb;
}

.text-input {
  flex: 1;
}

.token-input {
  margin-top: 14rpx;
}

.connect-button {
  width: 128rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 6rpx;
  background: #1f7a62;
  color: #ffffff;
  font-size: 26rpx;
}

.summary-band {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin: 20rpx 24rpx;
}

.summary-item,
.summary-action {
  min-height: 110rpx;
  padding: 18rpx;
  border: 1rpx solid #dfe7e3;
  border-radius: 8rpx;
  background: #ffffff;
}

.summary-item.wide {
  grid-column: span 2;
}

.summary-label {
  color: #63766f;
  font-size: 23rpx;
}

.summary-value {
  margin-top: 12rpx;
  color: #17332d;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.25;
  word-break: break-all;
}

.summary-value.accent {
  color: #1f7a62;
}

.summary-action {
  grid-column: span 2;
  min-height: 68rpx;
  line-height: 68rpx;
  padding: 0 18rpx;
  text-align: center;
  color: #ffffff;
  background: #1f7a62;
  font-size: 28rpx;
  font-weight: 700;
}

.section-title {
  margin-bottom: 18rpx;
  color: #17332d;
  font-size: 30rpx;
  font-weight: 700;
}

.metric-grid,
.batch-grid {
  display: grid;
  gap: 14rpx;
}

.metric-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.batch-grid {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.metric {
  min-height: 104rpx;
  padding: 16rpx;
  border: 1rpx solid #e2e9e6;
  border-radius: 6rpx;
  background: #fbfcfb;
  overflow: hidden;
}

.metric-label {
  color: #63766f;
  font-size: 23rpx;
  line-height: 1.3;
}

.metric-value {
  margin-top: 10rpx;
  color: #17332d;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.25;
  word-break: break-all;
}

.control-row,
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 76rpx;
  border-bottom: 1rpx solid #edf2f0;
}

.control-label {
  color: #243f39;
  font-size: 28rpx;
  font-weight: 600;
}

.picker-value {
  min-width: 160rpx;
  height: 56rpx;
  line-height: 56rpx;
  border: 1rpx solid #cbd8d2;
  border-radius: 6rpx;
  color: #1f4f46;
  text-align: center;
  font-size: 26rpx;
  background: #f7faf8;
}

.slider-row {
  padding: 18rpx 0 8rpx;
  border-bottom: 1rpx solid #edf2f0;
}

.button-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.command-button {
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 6rpx;
  background: #1f7a62;
  color: #ffffff;
  font-size: 26rpx;
}
