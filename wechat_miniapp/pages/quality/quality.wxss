.page {
  min-height: 100vh;
  background: #f3f6f4;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 28rpx 22rpx;
  background: #1f4f46;
  color: #ffffff;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
}

.refresh-button {
  width: 112rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 6rpx;
  color: #12653f;
  background: #d7f4e4;
  font-size: 25rpx;
}

.content {
  height: calc(100vh - 104rpx);
}

.headline {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin: 20rpx 24rpx;
}

.headline-main,
.headline-wide,
.section {
  border: 1rpx solid #dfe7e3;
  border-radius: 8rpx;
  background: #ffffff;
}

.headline-main,
.headline-wide {
  min-height: 112rpx;
  padding: 18rpx;
}

.headline-wide {
  grid-column: span 2;
}

.headline-label,
.metric-label,
.list-label {
  color: #63766f;
  font-size: 23rpx;
}

.headline-value {
  margin-top: 12rpx;
  color: #17332d;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.25;
  word-break: break-all;
}

.headline-value.accent {
  color: #1f7a62;
}

.section {
  margin: 20rpx 24rpx;
  padding: 22rpx;
}

.section-title {
  margin-bottom: 18rpx;
  color: #17332d;
  font-size: 30rpx;
  font-weight: 700;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.metric {
  min-height: 104rpx;
  padding: 16rpx;
  border: 1rpx solid #e2e9e6;
  border-radius: 6rpx;
  background: #fbfcfb;
  overflow: hidden;
}

.metric-value {
  margin-top: 10rpx;
  color: #17332d;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
  word-break: break-all;
}

.list-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #edf2f0;
}

.list-row:last-child {
  border-bottom: 0;
}

.list-value {
  flex: 1;
  color: #17332d;
  font-size: 27rpx;
  font-weight: 600;
  text-align: right;
  line-height: 1.35;
  word-break: break-all;
}
